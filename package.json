        "lint": "eslint .",
        "test": "SCRIBE_APP_PORT=0 TS_NODE_TRANSPILE_ONLY=1 node_modules/.bin/mocha",
        "start": "node_modules/.bin/ts-node src/scribe.cli.ts"
    },
    "repository": {
        "type": "git",
