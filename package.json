    },
    "homepage": "https://github.com/thoughtpivot/scribe#readme",
    "dependencies": {
        "@aws-sdk/rds-signer": "3.1041.0",
        "@redis/client": "^5.12.1",
        "ajv": "8.20.0",
        "ajv-formats": "^3.0.1",
        "diff-match-patch": "^1.0.5",
        "dotenv": "^17.4.2",
        "express": "5.2.1",
        "express-bunyan-logger": "1.3.3",
        "luxon": "3.7.2",
        "mkdirp": "3.0.1",
