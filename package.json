        "eslint-plugin-mocha": "11.2.0",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "eslint-plugin-sort-class-members": "1.22.1",
        "mocha": "11.7.5",
