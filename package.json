        "@types/chai": "5.2.3",
        "@types/diff-match-patch": "^1.0.36",
        "@types/express": "5.0.6",
        "@types/express-serve-static-core": "^5.1.1",
        "@types/lodash": "^4.17.24",
        "@types/luxon": "3.7.1",
        "@types/mocha": "10.0.10",
        "@types/node": "^22.15.3",
        "@types/pg": "^8.20.0",
        "@types/pluralize": "0.0.33",
