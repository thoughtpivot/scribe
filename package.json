{
    "name": "@thoughtpivot/scribe",
    "version": "1.0.9",
    "description": "Database modeling services (ThoughtPivot technology).",
    "exports": "./dist/scribe.cli.js",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
